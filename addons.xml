<?xml version="1.0" encoding="UTF-8"?>
<addons>

    <!-- CarlFusion Repository -->

    <addon id="repository.carlfusion"
           name="CarlFusion Repository"
           version="1.0"
           provider-name="Carl32623">

        <extension point="xbmc.addon.repository"
                   name="CarlFusion Repository">

            <dir>
                <info compressed="false">
                    https://carl32623.github.io/Arctic-Kodi-Build/addons.xml
                </info>

                <checksum>
                    https://carl32623.github.io/Arctic-Kodi-Build/addons.xml.md5
                </checksum>

                <datadir zip="true">
                    https://carl32623.github.io/Arctic-Kodi-Build/
                </datadir>
            </dir>

        </extension>

        <extension point="xbmc.addon.metadata">
            <summary>CarlFusion Kodi Repository</summary>
            <description>Repository for the CarlFusion Kodi Build</description>
            <platform>all</platform>
        </extension>

    </addon>



    <!-- Future CarlFusion Wizard Addon -->
    <!-- Placeholder for upcoming wizard addon -->

    <addon id="plugin.program.carlfusionwizard"
           name="CarlFusion Wizard"
           version="1.0"
           provider-name="Carl32623">

        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
        </requires>

        <extension point="xbmc.python.pluginsource"
                   library="default.py">
            <provides>executable</provides>
        </extension>

        <extension point="xbmc.addon.metadata">
            <summary>CarlFusion Build Wizard</summary>
            <description>Wizard installer for the CarlFusion Kodi Build</description>
            <platform>all</platform>
        </extension>

    </addon>

</addons>